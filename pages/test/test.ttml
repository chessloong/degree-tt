<view class="container">
  <!-- SVG图标测试区域 - 直接引用文件路径 -->
  <view class="de-card">
    <view class="de-card-header">
      <view class="de-card-title-left">
        <view class="de-card-dot"></view>
        <text class="de-card-title">SVG图标测试（直接引用）</text>
      </view>
    </view>
    <view class="de-card-content">
      <view class="svg-test-grid">
        <view class="svg-test-item">
          <image class="svg-test-icon" src="/assets/svg/more.svg" mode="aspectFit" />
          <text class="svg-test-label">more.svg</text>
        </view>
        <view class="svg-test-item">
          <image class="svg-test-icon" src="/assets/svg/redo.svg" mode="aspectFit" />
          <text class="svg-test-label">redo.svg</text>
        </view>
        <view class="svg-test-item">
          <image class="svg-test-icon" src="/assets/svg/money.svg" mode="aspectFit" />
          <text class="svg-test-label">money.svg</text>
        </view>
        <view class="svg-test-item">
          <image class="svg-test-icon" src="/assets/svg/clear.svg" mode="aspectFit" />
          <text class="svg-test-label">clear.svg</text>
        </view>
        <view class="svg-test-item">
          <image class="svg-test-icon" src="/assets/svg/class.svg" mode="aspectFit" />
          <text class="svg-test-label">class.svg</text>
        </view>
        <view class="svg-test-item">
          <image class="svg-test-icon" src="/assets/svg/score.svg" mode="aspectFit" />
          <text class="svg-test-label">score.svg</text>
        </view>
        <view class="svg-test-item">
          <image class="svg-test-icon" src="/assets/svg/supermanager.svg" mode="aspectFit" />
          <text class="svg-test-label">supermanager.svg</text>
        </view>
        <view class="svg-test-item">
          <image class="svg-test-icon" src="/assets/svg/free.svg" mode="aspectFit" />
          <text class="svg-test-label">free.svg</text>
        </view>
        <view class="svg-test-item">
          <image class="svg-test-icon" src="/assets/svg/caution.svg" mode="aspectFit" />
          <text class="svg-test-label">caution.svg</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 测试卡片样式 -->
  <view class="de-card">
    <view class="de-card-header">
      <view class="de-card-title-left">
        <view class="de-card-dot"></view>
        <text class="de-card-title">测试卡片标题1</text>
      </view>
      <view class="de-card-icons">
        <image class="de-card-icon-item" src="/assets/svg/more.svg" mode="aspectFit" />
        <image class="de-card-icon-item" src="/assets/svg/more.svg" mode="aspectFit" />
      </view>
    </view>
    <view class="de-card-content">
      <text class="de-card-text">这是卡片内容区域，可以根据内容自动伸缩高度。</text>
      <view style="margin-top: 20rpx;">
        <text class="de-card-text">测试内容行121313132 1</text>
      </view>
      <view style="margin-top: 20rpx;">
        <text class="de-card-text">测试内容行 2</text>
      </view>
      <view style="margin-top: 20rpx;">
        <text class="">测试内容行 3</text>
      </view>
    </view>
  </view>

  <!-- 第二个测试卡片 - 图表 -->
  <view class="de-card">
    <view class="de-card-header">
      <view class="de-card-title-left">
        <view class="de-card-dot"></view>
        <text class="de-card-title">数据图表</text>
      </view>
      <view class="de-card-icons">
        <image class="de-card-icon-item" src="/assets/svg/more.svg" mode="aspectFit" />
      </view>
    </view>
    <view class="de-card-content">
      <canvas id="myChart" canvas-id="myChart" class="de-chart-canvas"></canvas>
    </view>
  </view>

  <!-- 第三个测试卡片 - 表格 -->
  <view class="de-card">
    <view class="de-card-header">
      <view class="de-card-title-left">
        <view class="de-card-dot"></view>
        <text class="de-card-title">数据表格</text>
      </view>
      <view class="de-card-icons">
        <image class="de-card-icon-item" src="/assets/svg/redo.svg" mode="aspectFit" />
      </view>
    </view>
    <view class="de-card-content">
      <view class="de-table">
        <!-- 表头 -->
        <view class="de-table-header">
          <view class="de-table-cell de-table-cell-center">序号</view>
          <view class="de-table-cell">姓名</view>
          <view class="de-table-cell de-table-cell-right">分数</view>
        </view>
        <!-- 数据行 -->
        <view class="de-table-row de-table-row-alt">
          <view class="de-table-cell de-table-cell-center">1</view>
          <view class="de-table-cell">张三</view>
          <view class="de-table-cell de-table-cell-number">95</view>
        </view>
        <view class="de-table-row">
          <view class="de-table-cell de-table-cell-center">2</view>
          <view class="de-table-cell">李四这是一个非常长的名字用来测试单元格内容较多时的自动折行效果</view>
          <view class="de-table-cell de-table-cell-number">88</view>
        </view>
        <view class="de-table-row de-table-row-alt">
          <view class="de-table-cell de-table-cell-center">3</view>
          <view class="de-table-cell">王五</view>
          <view class="de-table-cell de-table-cell-number">92</view>
        </view>
        <view class="de-table-row">
          <view class="de-table-cell de-table-cell-center">4</view>
          <view class="de-table-cell">赵六</view>
          <view class="de-table-cell de-table-cell-number">85</view>
        </view>
        <view class="de-table-row de-table-row-alt">
          <view class="de-table-cell de-table-cell-center">5</view>
          <view class="de-table-cell">这是一段很长的备注信息，用来测试当单元格内容非常多时是否能够正常换行显示而不会溢出</view>
          <view class="de-table-cell de-table-cell-number">78</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 第四个测试卡片 - 平滑折线图 -->
  <view class="de-card">
    <view class="de-card-header">
      <view class="de-card-title-left">
        <view class="de-card-dot"></view>
        <text class="de-card-title">趋势分析</text>
      </view>
      <view class="de-card-icons">
        <image class="de-card-icon-item" src="/assets/svg/more.svg" mode="aspectFit" />
      </view>
    </view>
    <view class="de-card-content">
      <canvas id="lineChart" canvas-id="lineChart" class="de-chart-canvas"></canvas>
    </view>
  </view>

  <!-- 第五个测试 - 列表示例 -->
  <view class="de-list-group">
    <!-- 带图标、文字、右箭头 -->
    <view class="de-list-item de-list-item-clickable">
      <image class="de-list-icon" src="/assets/svg/more.svg" mode="aspectFit" />
      <view class="de-list-title-wrapper">
        <text class="de-list-title">个人资料</text>
        <text class="de-list-desc">完善个人信息以便更好地为您服务，包括头像、昵称、联系方式等</text>
      </view>
      <view class="de-list-content">
        <text class="de-list-text">张三</text>
        <image class="de-list-arrow" src="/assets/svg/arrow-right.svg" mode="aspectFit" />
      </view>
    </view>
    
    <!-- 带图标、文字、开关 -->
    <view class="de-list-item">
      <image class="de-list-icon" src="/assets/svg/money.svg" mode="aspectFit" />
      <view class="de-list-title-wrapper">
        <text class="de-list-title">消息通知</text>
        <text class="de-list-desc">接收重要通知和学习提醒，包括课程更新、考试安排、系统公告等重要信息推送</text>
      </view>
      <view class="de-list-content">
        <switch checked color="#0081ff" />
      </view>
    </view>
    
    <!-- 只有图标和文字 -->
    <view class="de-list-item de-list-item-last">
      <image class="de-list-icon" src="/assets/svg/caution.svg" mode="aspectFit" />
      <view class="de-list-title-wrapper">
        <text class="de-list-title">版本号</text>
      </view>
      <view class="de-list-content">
        <text class="de-list-text">v1.0.0</text>
      </view>
    </view>
  </view>

  <!-- 第六个测试 - 列表带选择器 -->
  <view class="de-list-group">
    <!-- 单列选择器 -->
    <view class="de-list-item de-list-item-clickable">
      <image class="de-list-icon" src="/assets/svg/class.svg" mode="aspectFit" />
      <view class="de-list-title-wrapper">
        <text class="de-list-title">年级选择</text>
      </view>
      <view class="de-list-content">
        <text class="de-list-text">高三</text>
        <image class="de-list-arrow" src="/assets/svg/arrow-right.svg" mode="aspectFit" />
      </view>
    </view>
    
    <!-- 多列选择器 -->
    <view class="de-list-item de-list-item-clickable">
      <image class="de-list-icon" src="/assets/svg/class.svg" mode="aspectFit" />
      <view class="de-list-title-wrapper">
        <text class="de-list-title">学科选择</text>
      </view>
      <view class="de-list-content">
        <text class="de-list-text">语文、数学、英语</text>
        <image class="de-list-arrow" src="/assets/svg/arrow-right.svg" mode="aspectFit" />
      </view>
    </view>
    
    <!-- 时间选择器 -->
    <view class="de-list-item de-list-item-clickable de-list-item-last">
      <image class="de-list-icon" src="/assets/svg/class.svg" mode="aspectFit" />
      <view class="de-list-title-wrapper">
        <text class="de-list-title">目标日期</text>
      </view>
      <view class="de-list-content">
        <text class="de-list-text">2024-06-07</text>
        <image class="de-list-arrow" src="/assets/svg/arrow-right.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <!-- 第七个测试 - 操作按钮 -->
  <view class="de-card">
    <view class="de-card-header">
      <view class="de-card-title-left">
        <view class="de-card-dot"></view>
        <text class="de-card-title">操作按钮</text>
      </view>
    </view>
    <view class="de-card-content">
      <view class="de-btn-group">
        <button class="de-btn de-btn-primary">主要按钮</button>
        <button class="de-btn de-btn-secondary">次要按钮</button>
        <button class="de-btn de-btn-outline">描边按钮</button>
      </view>
      <view class="de-btn-group">
        <button class="de-btn de-btn-primary de-btn-sm">小按钮</button>
        <button class="de-btn de-btn-secondary de-btn-sm">小按钮</button>
        <button class="de-btn de-btn-outline de-btn-sm">小按钮</button>
      </view>
      <view class="de-btn-group">
        <button class="de-btn de-btn-danger">危险按钮</button>
        <button class="de-btn de-btn-disabled" disabled>禁用按钮</button>
      </view>
    </view>
  </view>
</view>
