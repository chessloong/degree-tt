<view class="container">
  <!-- 测试卡片样式 -->
  <view class="de-card">
    <view class="de-card-header">
      <view class="de-card-title-left">
        <view class="de-card-dot"></view>
        <text class="de-card-title">测试卡片标题1</text>
      </view>
      <view class="de-card-icons">
        <icon type="info" size="20" color="#0081ff" class="de-card-icon-item" />
        <icon type="download" size="20" color="#0081ff" class="de-card-icon-item" />
      </view>
    </view>
    <view class="de-card-content">
      <text class="de-card-text">这是卡片内容区域，可以根据内容自动伸缩高度。</text>
      <view style="margin-top: 20rpx;">
        <text class="de-card-text">测试内容行121313132 1</text>
      </view>
      <view style="margin-top: 20rpx;">
        <text class="de-card-text">测试内容行 2</text>
      </view>
      <view style="margin-top: 20rpx;">
        <text class="">测试内容行 3</text>
      </view>
    </view>
  </view>

  <!-- 第二个测试卡片 - 图表 -->
  <view class="de-card">
    <view class="de-card-header">
      <view class="de-card-title-left">
        <view class="de-card-dot"></view>
        <text class="de-card-title">数据图表</text>
      </view>
      <view class="de-card-icons">
        <icon type="search" size="20" color="#0081ff" class="de-card-icon-item" />
      </view>
    </view>
    <view class="de-card-content">
      <canvas id="myChart" canvas-id="myChart" class="de-chart-canvas"></canvas>
    </view>
  </view>

  <!-- 第三个测试卡片 - 表格 -->
  <view class="de-card">
    <view class="de-card-header">
      <view class="de-card-title-left">
        <view class="de-card-dot"></view>
        <text class="de-card-title">数据表格</text>
      </view>
      <view class="de-card-icons">
        <icon type="download" size="20" color="#0081ff" class="de-card-icon-item" />
      </view>
    </view>
    <view class="de-card-content">
      <view class="de-table">
        <!-- 表头 -->
        <view class="de-table-header">
          <view class="de-table-cell de-table-cell-center">序号</view>
          <view class="de-table-cell">姓名</view>
          <view class="de-table-cell de-table-cell-right">分数</view>
        </view>
        <!-- 数据行 -->
        <view class="de-table-row de-table-row-alt">
          <view class="de-table-cell de-table-cell-center">1</view>
          <view class="de-table-cell">张三</view>
          <view class="de-table-cell de-table-cell-number">95</view>
        </view>
        <view class="de-table-row">
          <view class="de-table-cell de-table-cell-center">2</view>
          <view class="de-table-cell">李四这是一个非常长的名字用来测试单元格内容较多时的自动折行效果</view>
          <view class="de-table-cell de-table-cell-number">88</view>
        </view>
        <view class="de-table-row de-table-row-alt">
          <view class="de-table-cell de-table-cell-center">3</view>
          <view class="de-table-cell">王五</view>
          <view class="de-table-cell de-table-cell-number">92</view>
        </view>
        <view class="de-table-row">
          <view class="de-table-cell de-table-cell-center">4</view>
          <view class="de-table-cell">赵六</view>
          <view class="de-table-cell de-table-cell-number">85</view>
        </view>
        <view class="de-table-row de-table-row-alt">
          <view class="de-table-cell de-table-cell-center">5</view>
          <view class="de-table-cell">这是一段很长的备注信息，用来测试当单元格内容非常多时是否能够正常换行显示而不会溢出</view>
          <view class="de-table-cell de-table-cell-number">78</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 第四个测试卡片 - 平滑折线图 -->
  <view class="de-card">
    <view class="de-card-header">
      <view class="de-card-title-left">
        <view class="de-card-dot"></view>
        <text class="de-card-title">趋势分析</text>
      </view>
      <view class="de-card-icons">
        <icon type="info" size="20" color="#0081ff" class="de-card-icon-item" />
      </view>
    </view>
    <view class="de-card-content">
      <canvas id="lineChart" canvas-id="lineChart" class="de-chart-canvas"></canvas>
    </view>
  </view>

  <!-- 第五个测试 - 列表示例 -->
  <view class="de-list-group">
    <!-- 带图标、文字、右箭头 -->
    <view class="de-list-item de-list-item-clickable">
      <icon type="info" size="20" color="#0081ff" class="de-list-icon" />
      <view class="de-list-title-wrapper">
        <text class="de-list-title">个人资料</text>
        <text class="de-list-desc">完善个人信息以便更好地为您服务，包括头像、昵称、联系方式等</text>
      </view>
      <view class="de-list-content">
        <text class="de-list-text">张三</text>
        <image class="de-list-arrow" src="data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTIiIGhlaWdodD0iMTIiIHZpZXdCb3g9IjAgMCAxMiAxMiIgZmlsbD0ibm9uZSIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cGF0aCBkPSJNNCAyTDggNkw0IDEwIiBzdHJva2U9IiM5OTkiIHN0cm9rZS13aWR0aD0iMiIgc3Ryb2tlLWxpbmVjYXA9InJvdW5kIiBzdHJva2UtbGluZWpvaW49InJvdW5kIi8+PC9zdmc+" />
      </view>
    </view>
    
    <!-- 带图标、文字、开关 -->
    <view class="de-list-item">
      <icon type="success" size="20" color="#39b54a" class="de-list-icon" />
      <view class="de-list-title-wrapper">
        <text class="de-list-title">消息通知</text>
        <text class="de-list-desc">接收重要通知和学习提醒，包括课程更新、考试安排、系统公告等重要信息推送</text>
      </view>
      <view class="de-list-content">
        <switch checked color="#0081ff" />
      </view>
    </view>
    
    <!-- 只有图标和文字 -->
    <view class="de-list-item de-list-item-last">
      <icon type="warn" size="20" color="#e54d42" class="de-list-icon" />
      <view class="de-list-title-wrapper">
        <text class="de-list-title">版本号</text>
      </view>
      <view class="de-list-content">
        <text class="de-list-text">v1.0.0</text>
      </view>
    </view>
  </view>

  <!-- 第六个测试 - 列表带选择器 -->
  <view class="de-list-group">
    <!-- 单列选择器 -->
    <view class="de-list-item de-list-item-clickable">
      <icon type="info" size="20" color="#0081ff" class="de-list-icon" />
      <text class="de-list-title">所在城市</text>
      <picker mode="selector" range="{{cities}}" value="{{cityIndex}}" bindchange="onCityChange">
        <view class="de-list-content">
          <text class="de-list-text">{{cities[cityIndex]}}</text>
          <image class="de-list-arrow" src="data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTIiIGhlaWdodD0iMTIiIHZpZXdCb3g9IjAgMCAxMiAxMiIgZmlsbD0ibm9uZSIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cGF0aCBkPSJNNCAyTDggNkw0IDEwIiBzdHJva2U9IiM5OTkiIHN0cm9rZS13aWR0aD0iMiIgc3Ryb2tlLWxpbmVjYXA9InJvdW5kIiBzdHJva2UtbGluZWpvaW49InJvdW5kIi8+PC9zdmc+" />
        </view>
      </picker>
    </view>
    
    <!-- 多列选择器 -->
    <view class="de-list-item de-list-item-clickable">
      <icon type="success" size="20" color="#39b54a" class="de-list-icon" />
      <text class="de-list-title">日期选择</text>
      <picker mode="multiSelector" range="{{dateRange}}" value="{{dateIndex}}" bindchange="onDateChange">
        <view class="de-list-content">
          <text class="de-list-text">{{dateRange[0][dateIndex[0]]}}年{{dateRange[1][dateIndex[1]]}}月</text>
          <image class="de-list-arrow" src="data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTIiIGhlaWdodD0iMTIiIHZpZXdCb3g9IjAgMCAxMiAxMiIgZmlsbD0ibm9uZSIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cGF0aCBkPSJNNCAyTDggNkw0IDEwIiBzdHJva2U9IiM5OTkiIHN0cm9rZS13aWR0aD0iMiIgc3Ryb2tlLWxpbmVjYXA9InJvdW5kIiBzdHJva2UtbGluZWpvaW49InJvdW5kIi8+PC9zdmc+" />
        </view>
      </picker>
    </view>
    
    <!-- 多列选择器 - 省市 -->
    <view class="de-list-item de-list-item-clickable">
      <icon type="download" size="20" color="#f37b1d" class="de-list-icon" />
      <text class="de-list-title">地区选择</text>
      <picker mode="multiSelector" range="{{regionRange}}" value="{{regionIndex}}" bindchange="onRegionChange" bindcolumnchange="onRegionColumnChange">
        <view class="de-list-content">
          <text class="de-list-text">{{regionRange[0][regionIndex[0]]}} - {{regionRange[1][regionIndex[1]]}}</text>
          <image class="de-list-arrow" src="data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTIiIGhlaWdodD0iMTIiIHZpZXdCb3g9IjAgMCAxMiAxMiIgZmlsbD0ibm9uZSIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cGF0aCBkPSJNNCAyTDggNkw0IDEwIiBzdHJva2U9IiM5OTkiIHN0cm9rZS13aWR0aD0iMiIgc3Ryb2tlLWxpbmVjYXA9InJvdW5kIiBzdHJva2UtbGluZWpvaW49InJvdW5kIi8+PC9zdmc+" />
        </view>
      </picker>
    </view>
    
    <!-- 时间选择器 -->
    <view class="de-list-item de-list-item-last de-list-item-clickable">
      <icon type="download" size="20" color="#f37b1d" class="de-list-icon" />
      <text class="de-list-title">预约时间</text>
      <picker mode="time" value="{{timeValue}}" bindchange="onTimeChange">
        <view class="de-list-content">
          <text class="de-list-text">{{timeValue}}</text>
          <image class="de-list-arrow" src="data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTIiIGhlaWdodD0iMTIiIHZpZXdCb3g9IjAgMCAxMiAxMiIgZmlsbD0ibm9uZSIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cGF0aCBkPSJNNCAyTDggNkw0IDEwIiBzdHJva2U9IiM5OTkiIHN0cm9rZS13aWR0aD0iMiIgc3Ryb2tlLWxpbmVjYXA9InJvdW5kIiBzdHJva2UtbGluZWpvaW49InJvdW5kIi8+PC9zdmc+" />
        </view>
      </picker>
    </view>
  </view>
</view>
